# mamba env launcher
function ma {
  wd=`pwd`

  cd "$MAMBA_ROOT_PREFIX/envs/"
  target=`/bin/ls -t | grep --color='none' "$1" | fzf -1 --exact`

  if [ ! -z "$target" ]; then
    micromamba activate "$target"
  fi

  cd "$wd"
}

