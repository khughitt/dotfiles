################################################################################
#
# Functions
#
# Files under shell/ are zsh configuration fragments and may use zsh syntax.
#
################################################################################

_shell_functions_dir="${${(%):-%x}:A:h}/functions.d"
if [ -d "$_shell_functions_dir" ]; then
  for file in "$_shell_functions_dir"/*.zsh(N); do
    source "$file"
  done
fi
unset _shell_functions_dir file

