################################################################################
#
# Aliases
#
# Files under shell/ are zsh configuration fragments and may use zsh syntax.
#
################################################################################

_shell_aliases_dir="${${(%):-%x}:A:h}/aliases.d"
if [ -d "$_shell_aliases_dir" ]; then
  for file in "$_shell_aliases_dir"/*.zsh(N); do
    source "$file"
  done
fi
unset _shell_aliases_dir file

