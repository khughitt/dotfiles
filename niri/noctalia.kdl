layout {

    focus-ring {
        active-color   "#9acbff"
        inactive-color "#121316"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#9acbff"
        inactive-color "#121316"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#9acbff"
        inactive-color "#004a79"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#9acbff80"
    }
}

recent-windows {
    highlight {
        active-color "#9acbff"
        urgent-color "#ffb4ab"
    }
}
