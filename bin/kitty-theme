class KittyThemeError(RuntimeError):
    """Base error for expected CLI failures."""


class ProjectRegistryError(KittyThemeError):
    """Raised when the project registry is invalid."""


def read_metadata_text(metadata_path: Path) -> str:
    try:
        return metadata_path.read_text(encoding="utf-8")
    except (OSError, UnicodeDecodeError) as exc:
        raise KittyThemeError(f"failed to parse metadata file: {metadata_path.resolve(strict=False)}") from exc


def parse_toml_metadata(metadata_path: Path) -> dict[str, object]:
    try:
        parsed = tomllib.loads(read_metadata_text(metadata_path))
    except tomllib.TOMLDecodeError as exc:
        raise KittyThemeError(f"failed to parse metadata file: {metadata_path.resolve(strict=False)}") from exc
    if not isinstance(parsed, dict):
        raise KittyThemeError(f"failed to parse metadata file: {metadata_path.resolve(strict=False)}")
    return parsed


def parse_json_metadata(metadata_path: Path) -> object:
    try:
        return json.loads(read_metadata_text(metadata_path))
    except JSONDecodeError as exc:
        raise KittyThemeError(f"failed to parse metadata file: {metadata_path.resolve(strict=False)}") from exc


def default_registry_path() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "semantic-projects.txt"


def default_cache_path() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "semantic-themes.json"


def default_themes_dir() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "themes"


def default_stopwords_path() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "semantic-stopwords.txt"


def default_runtime_state_path() -> Path:
    return Path.home() / ".cache" / "kitty" / "semantic-runtime-state.json"


@dataclass(frozen=True, slots=True)
class SemanticProjectInput:
    project_root: Path
    corpus: str


@dataclass(frozen=True, slots=True)
class SemanticProjectCacheEntry:
    project_root: Path
    cluster_id: str
    confidence: float
    target_theme: str

    def to_json_data(self) -> dict[str, object]:
        return {
            "cluster_id": self.cluster_id,
            "confidence": self.confidence,
            "project_root": str(self.project_root),
            "target_theme": self.target_theme,
        }

    @classmethod
    def from_json_data(cls, raw_entry: object, cache_path: Path) -> SemanticProjectCacheEntry:
        if not isinstance(raw_entry, dict):
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        project_root = raw_entry.get("project_root")
        cluster_id = raw_entry.get("cluster_id")
        confidence = raw_entry.get("confidence")
        target_theme = raw_entry.get("target_theme")

        if not isinstance(project_root, str) or not project_root:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(cluster_id, str) or not cluster_id:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(confidence, (int, float)) or isinstance(confidence, bool):
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(target_theme, str) or not target_theme:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        normalized_project_root = Path(project_root).expanduser()
        if not normalized_project_root.is_absolute():
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        return cls(
            project_root=normalized_project_root.resolve(strict=False),
            cluster_id=cluster_id,
            confidence=float(confidence),
            target_theme=target_theme,
        )


@dataclass(frozen=True, slots=True)
class SemanticExcludedProjectCacheEntry:
    project_root: Path
    reason: str
    token_count: int
    unique_token_count: int

    def to_json_data(self) -> dict[str, object]:
        return {
            "project_root": str(self.project_root),
            "reason": self.reason,
            "token_count": self.token_count,
            "unique_token_count": self.unique_token_count,
        }

    @classmethod
    def from_json_data(cls, raw_entry: object, cache_path: Path) -> SemanticExcludedProjectCacheEntry:
        if not isinstance(raw_entry, dict):
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        project_root = raw_entry.get("project_root")
        reason = raw_entry.get("reason")
        token_count = raw_entry.get("token_count")
        unique_token_count = raw_entry.get("unique_token_count")

        if not isinstance(project_root, str) or not project_root:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(reason, str) or not reason:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if (
            not isinstance(token_count, int)
            or isinstance(token_count, bool)
            or token_count < 0
            or not isinstance(unique_token_count, int)
            or isinstance(unique_token_count, bool)
            or unique_token_count < 0
            or unique_token_count > token_count
        ):
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        normalized_project_root = Path(project_root).expanduser()
        if not normalized_project_root.is_absolute():
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        return cls(
            project_root=normalized_project_root.resolve(strict=False),
            reason=reason,
            token_count=token_count,
            unique_token_count=unique_token_count,
        )


@dataclass(frozen=True, slots=True)
class SemanticThemeCache:
    version: int
    backend: str
    cluster_count: int
    projects: list[SemanticProjectCacheEntry]
    excluded_projects: list[SemanticExcludedProjectCacheEntry] = field(default_factory=list)

    def to_json_data(self) -> dict[str, object]:
        payload: dict[str, object] = {
            "backend": self.backend,
            "cluster_count": self.cluster_count,
            "excluded_projects": [project.to_json_data() for project in self.excluded_projects],
            "projects": [project.to_json_data() for project in self.projects],
            "version": self.version,
        }
        return payload

    def to_json_text(self) -> str:
        return json.dumps(self.to_json_data(), indent=2, sort_keys=True) + "\n"


