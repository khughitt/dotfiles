#!/usr/bin/env python3
from __future__ import annotations

import json
import re
import tomllib
from dataclasses import dataclass
from pathlib import Path
from typing import Protocol

import click
from rich.console import Console


STDOUT = Console()
STDERR = Console(stderr=True)

DOC_FILENAMES = ("readme.md", "readme.rst", "readme.txt", "readme")
DOC_SUFFIXES = {".md", ".rst", ".txt", ".adoc"}
DOC_BASENAME_PRIORITY = ("index", "readme", "overview", "guide", "getting-started")
MAX_UV_LOCK_PACKAGES = 4
MAX_UNSUPPORTED_SKIP_LINES = 4
MAX_OVERSIZED_SKIP_LINES = 4
SEMANTIC_CACHE_VERSION = 1
SEMANTIC_CACHE_BACKEND = "deterministic-placeholder-v1"
METADATA_FILENAMES = (
    "pyproject.toml",
    "package.json",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "uv.lock",
)
SUPPORTED_CODE_SUFFIXES = {
    ".py",
    ".js",
    ".jsx",
    ".ts",
    ".tsx",
    ".rs",
    ".go",
    ".lua",
    ".nix",
    ".sh",
    ".zsh",
}
IGNORED_DIR_NAMES = {
    ".git",
    ".hg",
    ".svn",
    ".venv",
    ".mypy_cache",
    ".pytest_cache",
    "__pycache__",
    "node_modules",
    "dist",
    "build",
    "target",
}


class KittyThemeError(RuntimeError):
    """Base error for expected CLI failures."""


class ProjectRegistryError(KittyThemeError):
    """Raised when the project registry is invalid."""


def default_registry_path() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "semantic-projects.txt"


def default_cache_path() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "semantic-themes.json"


def default_themes_dir() -> Path:
    return Path(__file__).resolve().parents[1] / "kitty" / "themes"


@dataclass(frozen=True, slots=True)
class SemanticProjectInput:
    project_root: Path
    corpus: str


@dataclass(frozen=True, slots=True)
class SemanticProjectCacheEntry:
    project_root: Path
    cluster_id: str
    confidence: float
    target_theme: str

    def to_json_data(self) -> dict[str, object]:
        return {
            "cluster_id": self.cluster_id,
            "confidence": self.confidence,
            "project_root": str(self.project_root),
            "target_theme": self.target_theme,
        }

    @classmethod
    def from_json_data(cls, raw_entry: object, cache_path: Path) -> SemanticProjectCacheEntry:
        if not isinstance(raw_entry, dict):
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        project_root = raw_entry.get("project_root")
        cluster_id = raw_entry.get("cluster_id")
        confidence = raw_entry.get("confidence")
        target_theme = raw_entry.get("target_theme")

        if not isinstance(project_root, str) or not project_root:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(cluster_id, str) or not cluster_id:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(confidence, (int, float)) or isinstance(confidence, bool):
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")
        if not isinstance(target_theme, str) or not target_theme:
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        normalized_project_root = Path(project_root).expanduser()
        if not normalized_project_root.is_absolute():
            raise KittyThemeError(f"semantic cache is malformed: {cache_path}")

        return cls(
            project_root=normalized_project_root.resolve(strict=False),
            cluster_id=cluster_id,
            confidence=float(confidence),
            target_theme=target_theme,
        )


@dataclass(frozen=True, slots=True)
class SemanticThemeCache:
    version: int
    backend: str
    projects: list[SemanticProjectCacheEntry]

    def to_json_data(self) -> dict[str, object]:
        return {
            "backend": self.backend,
            "projects": [project.to_json_data() for project in self.projects],
            "version": self.version,
        }

    def to_json_text(self) -> str:
        return json.dumps(self.to_json_data(), indent=2, sort_keys=True) + "\n"


class SemanticAssignmentBackend(Protocol):
    @property
    def backend_name(self) -> str: ...

    def assign_projects(
        self, project_inputs: list[SemanticProjectInput], theme_targets: list[str]
    ) -> list[SemanticProjectCacheEntry]: ...


@dataclass(frozen=True, slots=True)
class DeterministicPlaceholderBackend:
    @property
    def backend_name(self) -> str:
        return SEMANTIC_CACHE_BACKEND

    def assign_projects(
        self, project_inputs: list[SemanticProjectInput], theme_targets: list[str]
    ) -> list[SemanticProjectCacheEntry]:
        if not theme_targets:
            raise KittyThemeError("semantic theme target list is empty")

        assignments: list[SemanticProjectCacheEntry] = []
        for project_index, project_input in enumerate(project_inputs):
            _ = project_input.corpus
            theme_index = project_index % len(theme_targets)
            assignments.append(
                SemanticProjectCacheEntry(
                    project_root=project_input.project_root,
                    cluster_id=f"cluster-{theme_index:04d}",
                    confidence=1.0,
                    target_theme=theme_targets[theme_index],
                )
            )
        return assignments


def normalize_project_root(raw_path: str, registry_path: Path) -> Path:
    candidate = Path(raw_path).expanduser()
    if not candidate.is_absolute():
        candidate = registry_path.parent / candidate

    normalized_path = candidate.resolve(strict=False)
    if not normalized_path.exists():
        raise ProjectRegistryError(f"configured project root does not exist: {normalized_path}")
    if not normalized_path.is_dir():
        raise ProjectRegistryError(f"configured project root is not a directory: {normalized_path}")
    return normalized_path


def parse_project_registry(registry_path: Path) -> list[Path]:
    normalized_registry_path = registry_path.expanduser().resolve(strict=False)
    if not normalized_registry_path.is_file():
        raise ProjectRegistryError(f"project registry not found: {normalized_registry_path}")

    try:
        registry_lines = normalized_registry_path.read_text(encoding="utf-8").splitlines()
    except (OSError, UnicodeDecodeError) as exc:
        raise ProjectRegistryError(f"failed to read project registry: {normalized_registry_path}") from exc

    project_roots: list[Path] = []
    seen_roots: set[Path] = set()
    for raw_line in registry_lines:
        stripped_line = raw_line.strip()
        if not stripped_line or stripped_line.startswith("#"):
            continue

        normalized_root = normalize_project_root(stripped_line, normalized_registry_path)
        if normalized_root in seen_roots:
            continue

        seen_roots.add(normalized_root)
        project_roots.append(normalized_root)

    return project_roots


def build_project_corpus(
    project_root: Path,
    *,
    max_code_files: int = 12,
    max_code_bytes: int = 24_000,
    max_file_bytes: int = 8_000,
) -> str:
    normalized_root = project_root.expanduser().resolve(strict=False)
    if not normalized_root.exists():
        raise KittyThemeError(f"project root does not exist: {normalized_root}")
    if not normalized_root.is_dir():
        raise KittyThemeError(f"project root is not a directory: {normalized_root}")

    doc_paths = discover_doc_files(normalized_root)
    metadata_paths = discover_metadata_files(normalized_root)
    doc_set = {path.relative_to(normalized_root) for path in doc_paths}
    metadata_set = {path.relative_to(normalized_root) for path in metadata_paths}

    sections: list[str] = []
    sections.extend(render_doc_section(normalized_root, doc_path) for doc_path in doc_paths)
    sections.extend(render_metadata_section(normalized_root, metadata_path) for metadata_path in metadata_paths)

    code_sections, skip_lines = sample_code_sections(
        normalized_root,
        doc_paths=doc_set,
        metadata_paths=metadata_set,
        max_code_files=max_code_files,
        max_code_bytes=max_code_bytes,
        max_file_bytes=max_file_bytes,
    )
    sections.extend(code_sections)
    sections.extend(skip_lines)

    return "\n\n".join(section for section in sections if section).strip()


def discover_doc_files(project_root: Path) -> list[Path]:
    doc_paths: list[Path] = []
    seen_paths: set[Path] = set()

    readme_candidates = [
        candidate
        for candidate in project_root.iterdir()
        if candidate.is_file() and candidate.name.lower() in DOC_FILENAMES
    ]
    for candidate in sorted(readme_candidates, key=readme_sort_key):
        seen_paths.add(candidate)
        doc_paths.append(candidate)

    docs_root = project_root / "docs"
    if docs_root.is_dir():
        for candidate in sorted(collect_project_files(docs_root), key=lambda path: doc_sort_key(project_root, path)):
            if candidate.is_file() and candidate.suffix.lower() in DOC_SUFFIXES and candidate not in seen_paths:
                seen_paths.add(candidate)
                doc_paths.append(candidate)

    return doc_paths


def readme_sort_key(readme_path: Path) -> tuple[int, str, str]:
    filename = readme_path.name
    return DOC_FILENAMES.index(filename.lower()), filename.lower(), filename


def doc_sort_key(project_root: Path, doc_path: Path) -> tuple[int, str, str]:
    stem = doc_path.stem.lower()
    try:
        basename_rank = DOC_BASENAME_PRIORITY.index(stem)
    except ValueError:
        basename_rank = len(DOC_BASENAME_PRIORITY)

    relative_path = doc_path.relative_to(project_root).as_posix()
    return basename_rank, relative_path.lower(), relative_path


def discover_metadata_files(project_root: Path) -> list[Path]:
    return [project_root / filename for filename in METADATA_FILENAMES if (project_root / filename).is_file()]


def render_doc_section(project_root: Path, doc_path: Path) -> str:
    relative_path = doc_path.relative_to(project_root)
    contents = doc_path.read_text(encoding="utf-8").strip()
    return f"DOC {relative_path.as_posix()}\n{contents}"


def render_metadata_section(project_root: Path, metadata_path: Path) -> str:
    relative_path = metadata_path.relative_to(project_root)
    summary_lines = summarize_metadata(metadata_path)
    if not summary_lines:
        return ""
    return f"METADATA {relative_path.as_posix()}\n" + "\n".join(summary_lines)


def summarize_metadata(metadata_path: Path) -> list[str]:
    if metadata_path.name == "pyproject.toml":
        return summarize_pyproject_metadata(metadata_path)
    if metadata_path.name == "package.json":
        return summarize_package_json_metadata(metadata_path)
    if metadata_path.name == "uv.lock":
        return summarize_uv_lock_metadata(metadata_path)
    if metadata_path.name in {"package-lock.json", "pnpm-lock.yaml", "yarn.lock"}:
        return [f"lockfile: {metadata_path.name}"]
    return []


def summarize_pyproject_metadata(metadata_path: Path) -> list[str]:
    data = tomllib.loads(metadata_path.read_text(encoding="utf-8"))
    project_data = data.get("project", {})
    if not isinstance(project_data, dict):
        return []

    summary_lines: list[str] = []
    for field in ("name", "description"):
        value = project_data.get(field)
        if isinstance(value, str) and value:
            summary_lines.append(f"{field}: {value}")

    dependencies = project_data.get("dependencies", [])
    if isinstance(dependencies, list):
        summary_lines.extend(f"dependency: {name}" for name in extract_requirement_names(dependencies))
    return summary_lines


def summarize_package_json_metadata(metadata_path: Path) -> list[str]:
    data = json.loads(metadata_path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        return []

    summary_lines: list[str] = []
    name = data.get("name")
    if isinstance(name, str) and name:
        summary_lines.append(f"name: {name}")

    scripts = data.get("scripts", {})
    if isinstance(scripts, dict):
        summary_lines.extend(f"script: {script_name}" for script_name in sorted(as_string_keys(scripts)))

    dependency_sections = ("dependencies", "devDependencies", "peerDependencies")
    dependency_names: set[str] = set()
    for section in dependency_sections:
        dependency_map = data.get(section, {})
        if isinstance(dependency_map, dict):
            dependency_names.update(as_string_keys(dependency_map))

    summary_lines.extend(f"dependency: {dependency}" for dependency in sorted(dependency_names))
    return summary_lines


def summarize_uv_lock_metadata(metadata_path: Path) -> list[str]:
    data = tomllib.loads(metadata_path.read_text(encoding="utf-8"))
    packages = data.get("package", [])
    if not isinstance(packages, list):
        return []

    package_names = sorted(
        package_name
        for package in packages
        if isinstance(package, dict)
        for package_name in [package.get("name")]
        if isinstance(package_name, str) and package_name
    )

    summary_lines = [f"package_count: {len(package_names)}"]
    summary_lines.extend(f"package: {package_name}" for package_name in package_names[:MAX_UV_LOCK_PACKAGES])
    remaining_packages = len(package_names) - MAX_UV_LOCK_PACKAGES
    if remaining_packages > 0:
        summary_lines.append(f"package_remaining: {remaining_packages}")
    return summary_lines


def extract_requirement_names(requirements: list[object]) -> list[str]:
    names: list[str] = []
    for requirement in requirements:
        if not isinstance(requirement, str):
            continue
        match = re.match(r"[A-Za-z0-9_.-]+", requirement.strip())
        if match is not None:
            names.append(match.group(0))
    return sorted(set(names))


def as_string_keys(values: dict[object, object]) -> set[str]:
    return {str(key) for key in values}


def sample_code_sections(
    project_root: Path,
    *,
    doc_paths: set[Path],
    metadata_paths: set[Path],
    max_code_files: int,
    max_code_bytes: int,
    max_file_bytes: int,
) -> tuple[list[str], list[str]]:
    code_sections: list[str] = []
    skip_lines: list[str] = []
    unsupported_paths: list[Path] = []
    oversized_paths: list[Path] = []
    sampled_file_count = 0
    sampled_byte_count = 0

    for candidate in iter_project_files(project_root):
        relative_path = candidate.relative_to(project_root)
        if relative_path in doc_paths or relative_path in metadata_paths:
            continue

        suffix = candidate.suffix.lower()
        if suffix not in SUPPORTED_CODE_SUFFIXES:
            unsupported_paths.append(relative_path)
            continue

        file_size = candidate.stat().st_size
        if file_size > max_file_bytes:
            oversized_paths.append(relative_path)
            continue

        if sampled_file_count >= max_code_files:
            continue
        if sampled_byte_count + file_size > max_code_bytes:
            continue

        contents = candidate.read_text(encoding="utf-8").strip()
        code_sections.append(f"CODE {relative_path.as_posix()}\n{contents}")
        sampled_file_count += 1
        sampled_byte_count += file_size

    skip_lines.extend(
        f"SKIP {relative_path.as_posix()} unsupported"
        for relative_path in unsupported_paths[:MAX_UNSUPPORTED_SKIP_LINES]
    )
    remaining_unsupported = len(unsupported_paths) - MAX_UNSUPPORTED_SKIP_LINES
    if remaining_unsupported > 0:
        skip_lines.append(f"SKIP unsupported {remaining_unsupported} more")
    skip_lines.extend(
        f"SKIP {relative_path.as_posix()} oversized" for relative_path in oversized_paths[:MAX_OVERSIZED_SKIP_LINES]
    )
    remaining_oversized = len(oversized_paths) - MAX_OVERSIZED_SKIP_LINES
    if remaining_oversized > 0:
        skip_lines.append(f"SKIP oversized {remaining_oversized} more")

    return code_sections, skip_lines


def iter_project_files(project_root: Path) -> list[Path]:
    return collect_project_files(project_root)


def collect_project_files(current_path: Path) -> list[Path]:
    project_files: list[Path] = []
    for candidate in sorted(current_path.iterdir(), key=path_name_sort_key):
        if candidate.is_dir():
            if candidate.name in IGNORED_DIR_NAMES:
                continue
            project_files.extend(collect_project_files(candidate))
            continue
        if candidate.is_file():
            project_files.append(candidate)
    return project_files


def path_name_sort_key(path: Path) -> tuple[str, str]:
    return path.name.lower(), path.name


def list_semantic_theme_targets(themes_dir: Path) -> list[str]:
    normalized_themes_dir = themes_dir.expanduser().resolve(strict=False)
    if not normalized_themes_dir.exists():
        raise KittyThemeError(f"kitty themes directory does not exist: {normalized_themes_dir}")
    if not normalized_themes_dir.is_dir():
        raise KittyThemeError(f"kitty themes path is not a directory: {normalized_themes_dir}")

    theme_paths = [
        candidate
        for candidate in sorted(normalized_themes_dir.iterdir(), key=path_name_sort_key)
        if candidate.is_file() and candidate.suffix == ".conf"
    ]
    theme_targets = [theme_path.name for theme_path in theme_paths]
    if not theme_targets:
        raise KittyThemeError(f"kitty themes directory has no .conf themes: {normalized_themes_dir}")
    return theme_targets


def build_semantic_cache(
    registry_path: Path,
    themes_dir: Path,
    backend: SemanticAssignmentBackend | None = None,
) -> SemanticThemeCache:
    project_roots = parse_project_registry(registry_path)
    theme_targets = list_semantic_theme_targets(themes_dir)
    project_inputs = [
        SemanticProjectInput(project_root=project_root, corpus=build_project_corpus(project_root))
        for project_root in project_roots
    ]
    semantic_backend = backend if backend is not None else DeterministicPlaceholderBackend()
    return SemanticThemeCache(
        version=SEMANTIC_CACHE_VERSION,
        backend=semantic_backend.backend_name,
        projects=semantic_backend.assign_projects(project_inputs, theme_targets),
    )


def write_semantic_cache(cache_path: Path, cache: SemanticThemeCache) -> None:
    normalized_cache_path = cache_path.expanduser().resolve(strict=False)
    normalized_cache_path.parent.mkdir(parents=True, exist_ok=True)
    normalized_cache_path.write_text(cache.to_json_text(), encoding="utf-8")


def load_semantic_cache(cache_path: Path) -> SemanticThemeCache:
    normalized_cache_path = cache_path.expanduser().resolve(strict=False)
    if not normalized_cache_path.is_file():
        raise KittyThemeError(f"semantic cache not found: {normalized_cache_path}")

    try:
        raw_contents = normalized_cache_path.read_text(encoding="utf-8")
    except (OSError, UnicodeDecodeError) as exc:
        raise KittyThemeError(f"failed to read semantic cache: {normalized_cache_path}") from exc

    try:
        raw_cache = json.loads(raw_contents)
    except json.JSONDecodeError as exc:
        raise KittyThemeError(f"semantic cache is malformed: {normalized_cache_path}") from exc

    if not isinstance(raw_cache, dict):
        raise KittyThemeError(f"semantic cache is malformed: {normalized_cache_path}")

    version = raw_cache.get("version")
    backend = raw_cache.get("backend")
    raw_projects = raw_cache.get("projects")
    if version != SEMANTIC_CACHE_VERSION or not isinstance(backend, str) or not isinstance(raw_projects, list):
        raise KittyThemeError(f"semantic cache is malformed: {normalized_cache_path}")

    return SemanticThemeCache(
        version=version,
        backend=backend,
        projects=[
            SemanticProjectCacheEntry.from_json_data(raw_project, normalized_cache_path) for raw_project in raw_projects
        ],
    )


def find_git_root(project_path: Path) -> Path:
    normalized_path = project_path.expanduser().resolve(strict=False)
    if not normalized_path.exists():
        raise KittyThemeError(f"path does not exist: {normalized_path}")

    candidate = normalized_path if normalized_path.is_dir() else normalized_path.parent
    while True:
        if (candidate / ".git").exists():
            return candidate
        if candidate.parent == candidate:
            break
        candidate = candidate.parent

    raise KittyThemeError(f"path is not inside a git repository: {normalized_path}")


def resolve_theme_for_path(project_path: Path, cache_path: Path) -> str:
    git_root = find_git_root(project_path)
    semantic_cache = load_semantic_cache(cache_path)
    for project in semantic_cache.projects:
        if project.project_root == git_root:
            return project.target_theme

    raise KittyThemeError(f"semantic cache has no entry for git root: {git_root}")


@click.group()
def cli() -> None:
    """Manage semantic kitty theme metadata."""


@cli.group()
def projects() -> None:
    """Manage the semantic project registry."""


@projects.command("validate")
@click.option(
    "--registry",
    type=click.Path(path_type=Path, dir_okay=False),
    default=default_registry_path,
    show_default=str(default_registry_path()),
)
def validate_projects(registry: Path) -> None:
    project_roots = parse_project_registry(registry)
    root_label = "root" if len(project_roots) == 1 else "roots"
    STDOUT.print(
        f"validated {len(project_roots)} project {root_label} from {registry.expanduser().resolve()}",
        soft_wrap=True,
    )


@cli.command("recompute")
@click.option(
    "--registry",
    type=click.Path(path_type=Path, dir_okay=False),
    default=default_registry_path,
    show_default=str(default_registry_path()),
)
@click.option(
    "--themes-dir",
    type=click.Path(path_type=Path, file_okay=False),
    default=default_themes_dir,
    show_default=str(default_themes_dir()),
)
@click.option(
    "--cache",
    type=click.Path(path_type=Path, dir_okay=False),
    default=default_cache_path,
    show_default=str(default_cache_path()),
)
def recompute_semantic_cache(registry: Path, themes_dir: Path, cache: Path) -> None:
    semantic_cache = build_semantic_cache(registry, themes_dir)
    write_semantic_cache(cache, semantic_cache)
    root_label = "root" if len(semantic_cache.projects) == 1 else "roots"
    STDOUT.print(
        f"wrote semantic cache for {len(semantic_cache.projects)} project {root_label} to "
        f"{cache.expanduser().resolve(strict=False)}",
        soft_wrap=True,
    )


@cli.command("resolve")
@click.argument("project_path", type=click.Path(path_type=Path))
@click.option(
    "--cache",
    type=click.Path(path_type=Path, dir_okay=False),
    default=default_cache_path,
    show_default=str(default_cache_path()),
)
def resolve_semantic_theme(project_path: Path, cache: Path) -> None:
    STDOUT.print(resolve_theme_for_path(project_path, cache), soft_wrap=True)


def main() -> int:
    try:
        cli(standalone_mode=False)
    except click.ClickException as exc:
        exc.show()
        return exc.exit_code
    except KittyThemeError as exc:
        STDERR.print(str(exc), soft_wrap=True)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
