from numpy.typing import NDArray
from rich.console import Console


STDOUT = Console()
STDERR = Console(stderr=True)

DOC_FILENAMES = ("readme.md", "readme.rst", "readme.txt", "readme")
DOC_SUFFIXES = {".md", ".rst", ".txt", ".adoc"}
DOC_BASENAME_PRIORITY = ("index", "readme", "overview", "guide", "getting-started")
MAX_UV_LOCK_PACKAGES = 4
MAX_UNSUPPORTED_SKIP_LINES = 4
MAX_OVERSIZED_SKIP_LINES = 4
SEMANTIC_CACHE_VERSION = 1
SEMANTIC_CACHE_BACKEND = "tfidf-svd-agglomerative-v1"
SEMANTIC_MIN_CLUSTERS = 4
SEMANTIC_MAX_CLUSTERS = 6
SEMANTIC_MAX_COMPONENTS = 8
SEMANTIC_CLUSTER_LABEL_TERMS = 3
SEMANTIC_LOW_CONFIDENCE_THRESHOLD = 0.25
SEMANTIC_SINGLETON_CONFIDENCE_CAP = 0.24
TOKEN_PATTERN = re.compile(r"[a-z][a-z0-9-]{2,}")
SEMANTIC_STOPWORDS = {
    "and",
    "build",
    "code",
    "dependency",
    "description",
    "doc",
    "docs",
    "file",
    "files",
    "guide",
    "index",
    "metadata",
    "name",
    "overview",
    "package",
    "packages",
    "project",
    "projects",
    "readme",
    "script",
    "scripts",
    "src",
    "theme",
    "tool",
    "tools",
}
METADATA_FILENAMES = (
    "pyproject.toml",
    "package.json",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "uv.lock",
)
