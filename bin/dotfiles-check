#!/usr/bin/env bash
set -euo pipefail

DOTS_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)"
cd "$DOTS_HOME"

bash_files=(
    setup.sh
    bin/dotfiles-check
    bin/dotfiles-health
    lib/dotfiles-setup-data.bash
    hypr/host_specific.sh
    hypr/scripts/monitor-handler.sh
    hypr/scripts/monitor-info.sh
    hypr/scripts/restore-wallpaper.sh
    niri/host_specific.sh
    niri/scripts/monitor-handler.sh
)

zsh_files=(
    zshrc
    zshenv
    shell/aliases
    shell/audio
    shell/functions
    shell/functions.d/dropbox.zsh
    shell/fzf
    shell/kitty
    shell/macos
    shell/tmux
    shell/ubuntu
    shell/vconsole
    shell/vi
    shell/wali
    shell/zoxide
    tests/dropbox_ignore_flux.zsh
    tests/setup_and_health.zsh
    tests/dotfiles_check.zsh
    tests/tmp_cleanup.zsh
)

while IFS= read -r file; do
    zsh_files+=("$file")
done < <(find shell -path 'shell/private' -prune -o -path 'shell/local' -prune -o -type f -name '*.zsh' -print | sort)

echo "bash -n"
bash -n "${bash_files[@]}"

echo "shellcheck"
shellcheck -x "${bash_files[@]}"

echo "zsh -n"
zsh -n "${zsh_files[@]}"

echo "zsh modelines"
if rg -n 'vi:syntax=bash' shell --glob '!private/**' --glob '!local/**'; then
    echo "shell files are zsh-sourced; use vi:syntax=zsh instead of vi:syntax=bash" >&2
    exit 1
fi

echo "dotfiles checks passed"
