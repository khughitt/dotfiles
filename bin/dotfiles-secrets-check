#!/usr/bin/env bash
set -euo pipefail

DOTS_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)"
GITLEAKS_BIN="${GITLEAKS_BIN:-gitleaks}"

if ! command -v "$GITLEAKS_BIN" >/dev/null 2>&1; then
    echo "Gitleaks is required; install it before running the secret scan" >&2
    exit 127
fi

exec "$GITLEAKS_BIN" git --redact=100 --no-banner "$DOTS_HOME"
