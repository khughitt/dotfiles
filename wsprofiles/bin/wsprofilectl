#!/usr/bin/env node
import { connect } from 'node:net';
import { ID_RE } from '../src/catalog.js';
import { SOCKET_PATH } from '../src/daemon.js';

const USAGE = 'usage: wsprofilectl <open|new> <profile-id>';

export function formatCommand(argv) {
  const [verb, id] = argv;
  if (
    argv.length !== 2 ||
    !['open', 'new'].includes(verb) ||
    !ID_RE.test(id) ||
    /-\d+$/.test(id)
  ) {
    throw new Error(USAGE);
  }
  return `${verb} ${id}\n`;
}

export function classifyReply(reply) {
  if (!reply.includes('\n')) {
    return { ok: false, message: `incomplete reply: ${reply}` };
  }
  if (reply.indexOf('\n') !== reply.length - 1) {
    return { ok: false, message: `unexpected reply: ${reply}` };
  }
  const line = reply.slice(0, -1);
  if (line === 'ok') return { ok: true };
  if (/^error .+/.test(line)) return { ok: false, message: line };
  return { ok: false, message: `unexpected reply: ${line}` };
}

if (import.meta.url === `file://${process.argv[1]}`) {
  let line;
  try {
    line = formatCommand(process.argv.slice(2));
  } catch (e) {
    console.error('wsprofilectl:', e.message);
    process.exit(1);
  }

  const sock = connect(SOCKET_PATH, () => { sock.write(line); });
  let reply = '';
  let done = false;
  const finish = (result) => {
    if (done) return;
    done = true;
    sock.end();
    if (!result.ok) {
      console.error('wsprofilectl:', result.message);
      process.exit(1);
    }
    process.exit(0);
  };
  sock.setEncoding('utf8');
  sock.on('data', (d) => {
    reply += d;
  });
  sock.on('end', () => {
    finish(classifyReply(reply));
  });
  sock.on('close', () => {
    finish(classifyReply(reply));
  });
  sock.on('error', (e) => {
    if (done) return;
    done = true;
    console.error('wsprofilectl:', e.message);
    process.exit(1);
  });
}
