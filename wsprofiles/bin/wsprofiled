#!/usr/bin/env node
import { spawn } from 'node:child_process';
import { createServer, connect } from 'node:net';
import {
  closeSync,
  existsSync,
  openSync,
  readFileSync,
  unlinkSync,
  watchFile,
  writeFileSync,
} from 'node:fs';
import { homedir } from 'node:os';
import { loadCatalog } from '../src/catalog.js';
import { generateKdl } from '../src/kdl.js';
import { parseEventLines, focusedName, focusWorkspace, loadConfig } from '../src/niri.js';
import { runCommands } from '../src/noctalia.js';
import { OccupancyTracker } from '../src/occupancy.js';
import { Daemon, SOCKET_PATH } from '../src/daemon.js';

const CATALOG = `${homedir()}/d/dotfiles/wsprofiles/profiles.yaml`;
const KDL_OUT = `${homedir()}/.config/niri/profiles.kdl`;
const STARTUP_LOCK = `${SOCKET_PATH}.startup-lock`;

const occupancy = new OccupancyTracker();
const buildDaemon = (cat) =>
  new Daemon({ catalog: cat, niri: { focusWorkspace }, noctalia: { runCommands }, occupancy });

// Refuse duplicate daemons and reserve the socket before doing any side effects
// such as catalog reads, KDL writes, niri reloads, watchers, or event streams.
const startupLock = await acquireStartupLock();
let controlServer;
let startupError = null;
try {
  if (await assertSingleInstance()) controlServer = await startControlSocket();
} catch (e) {
  startupError = e;
} finally {
  releaseStartupLock(startupLock);
}
if (startupError) {
  console.error(startupError.message);
  process.exit(1);
}
if (!controlServer) process.exit(0);

let catalog;
let daemon;
const nameById = new Map();
let reloadChain = Promise.resolve();

try {
  catalog = loadCatalog(CATALOG);
  const prevKdl = existsSync(KDL_OUT) ? readFileSync(KDL_OUT, 'utf8') : null;
  writeFileSync(KDL_OUT, generateKdl(catalog));
  try {
    await loadConfig();
  } catch (e) {
    console.error('wsprofiled: initial niri reload failed:', e.message);
    if (prevKdl !== null) {
      writeFileSync(KDL_OUT, prevKdl);
      await loadConfig().catch((restoreError) =>
        console.error('wsprofiled: restoring previous niri config failed:', restoreError.message));
    }
    controlServer.close();
    process.exit(1);
  }
  daemon = buildDaemon(catalog);
} catch (e) {
  console.error('wsprofiled: startup failed:', e.message);
  controlServer.close();
  process.exit(1);
}

// On catalog edits: regenerate the KDL, reload niri, and only swap in the new
// catalog if niri accepted it. On failure, revert the KDL and keep the
// old daemon so runtime state stays in sync with the compositor.
watchFile(CATALOG, { interval: 1000 }, () => {
  reloadChain = reloadChain
    .then(reloadCatalog, reloadCatalog)
    .catch((e) => console.error('wsprofiled: catalog reload failed:', e.message));
});

async function reloadCatalog() {
  let next;
  try {
    next = loadCatalog(CATALOG);
  } catch (e) {
    console.error('wsprofiled: catalog parse failed, keeping previous:', e.message);
    return;
  }
  const prevKdl = existsSync(KDL_OUT) ? readFileSync(KDL_OUT, 'utf8') : null;
  writeFileSync(KDL_OUT, generateKdl(next));
  try {
    await loadConfig();
  } catch (e) {
    console.error('wsprofiled: niri rejected new config, reverting:', e.message);
    if (prevKdl !== null) writeFileSync(KDL_OUT, prevKdl);
    await loadConfig().catch((restoreError) =>
      console.error('wsprofiled: restoring previous niri config failed:', restoreError.message));
    return;
  }
  catalog = next;
  daemon.updateCatalog(catalog);
}

async function acquireStartupLock() {
  for (;;) {
    try {
      const fd = openSync(STARTUP_LOCK, 'wx');
      writeFileSync(fd, `${process.pid}\n`);
      return { fd, path: STARTUP_LOCK };
    } catch (e) {
      if (e.code !== 'EEXIST') {
        console.error('wsprofiled: cannot acquire startup lock:', e.message);
        process.exit(1);
      }
      const probe = await probeSocket();
      if (probe.alive) {
        console.error('wsprofiled: another instance is already running; exiting.');
        process.exit(0);
      }
      if (probe.code && probe.code !== 'ENOENT' && probe.code !== 'ECONNREFUSED') {
        console.error(`wsprofiled: cannot probe existing socket (${probe.code}); exiting.`);
        process.exit(1);
      }
      const pid = readLockPid();
      if (!pid || isPidAlive(pid)) {
        console.error('wsprofiled: startup already in progress; exiting.');
        process.exit(1);
      }
      try {
        unlinkSync(STARTUP_LOCK);
      } catch (unlinkError) {
        if (unlinkError.code !== 'ENOENT') throw unlinkError;
      }
    }
  }
}

function readLockPid() {
  try {
    const text = readFileSync(STARTUP_LOCK, 'utf8').trim();
    const pid = Number.parseInt(text, 10);
    return Number.isInteger(pid) && pid > 0 ? pid : null;
  } catch {
    return null;
  }
}

function isPidAlive(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch (e) {
    return e.code !== 'ESRCH';
  }
}

function releaseStartupLock(lock) {
  try {
    closeSync(lock.fd);
  } catch (e) {
    console.error('wsprofiled: closing startup lock failed:', e.message);
  }
  try {
    unlinkSync(lock.path);
  } catch (e) {
    if (e.code !== 'ENOENT') console.error('wsprofiled: removing startup lock failed:', e.message);
  }
}

async function probeSocket() {
  if (!existsSync(SOCKET_PATH)) return { alive: false, code: 'ENOENT' };
  return new Promise((resolve) => {
    const probe = connect(SOCKET_PATH)
      .once('connect', () => { probe.end(); resolve({ alive: true }); })
      .once('error', (e) => resolve({ alive: false, code: e.code }));
  });
}

async function assertSingleInstance() {
  const result = await probeSocket();
  if (result.alive) {
    console.error('wsprofiled: another instance is already running; exiting.');
    return false;
  }
  if (result.code === 'ENOENT') return true;
  if (result.code !== 'ECONNREFUSED') {
    throw new Error(`wsprofiled: cannot probe existing socket (${result.code}); exiting.`);
  }
  unlinkSync(SOCKET_PATH);
  return true;
}

// Control socket for wsprofilectl. A second daemon has already been rejected by
// assertSingleInstance(), so this function reserves this instance's socket.
async function startControlSocket() {
  const server = createServer((sock) => {
    let buf = '';
    sock.on('data', (d) => {
      buf += d;
      const nl = buf.indexOf('\n');
      if (nl >= 0) {
        const line = buf.slice(0, nl).trim();
        sock.removeAllListeners('data');
        handleCommand(line, sock);
      }
    });
  });
  await new Promise((resolve, reject) => {
    server
      .once('listening', resolve)
      .once('error', (e) => reject(new Error(`wsprofiled: cannot bind control socket: ${e.message}`)))
      .listen(SOCKET_PATH);
  });
  return server;
}

// Await + catch each command so a failed focus never becomes an unhandled
// rejection, and the client gets an explicit ok/error reply.
async function handleCommand(line, sock) {
  const [cmd, id] = line.split(/\s+/);
  try {
    if (!['open', 'new'].includes(cmd)) throw new Error(`unknown command: ${cmd}`);
    if (!id) throw new Error(`missing profile id for ${cmd}`);
    if (!daemon) throw new Error('daemon is not ready');
    if (cmd === 'open') await daemon.open(id);
    else await daemon.new(id);
    sock.end('ok\n');
  } catch (e) {
    console.error('wsprofiled: command failed:', e.message);
    sock.end(`error ${e.message}\n`);
  }
}

const stream = spawn('niri', ['msg', '--json', 'event-stream'], { stdio: ['ignore', 'pipe', 'inherit'] });
let carry = '';
stream.stdout.setEncoding('utf8');
stream.stdout.on('data', (chunk) => {
  const { events, carry: c } = parseEventLines(chunk, carry);
  carry = c;
  for (const ev of events) {
    occupancy.apply(ev);
    if (ev.WorkspacesChanged) {
      nameById.clear();
      for (const ws of ev.WorkspacesChanged.workspaces) if (ws.name) nameById.set(ws.id, ws.name);
    }
    const name = focusedName(ev, nameById);
    if (name) daemon.onFocus(name);
  }
});
stream.on('exit', (code) => {
  console.error(`wsprofiled: niri event-stream exited (${code})`);
  process.exit(1);
});
