{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,

    // "include": [
    //     "~/.config/waybar/mcp-mode.json"
    // ],

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],

    "modules-center": [
        "hyprland/window"
    ],

    "modules-right": [
        "pulseaudio",
        "memory",
        "cpu",
        //"hyprland/language",
        "custom/pomodoro",
        "custom/layout",
        //"custom/mcp",
        "clock",
        "tray"
    ],

    // ==========================================
    // LEFT MODULES
    // ==========================================

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true,
        "all-outputs": false,
        "active-only": false
    },

    "hyprland/submap": {
        "format": " {}",
        "tooltip": false
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 80,
        "separate-outputs": true,
        "rewrite": {
            "(.*) — Mozilla Firefox": "󰈹 $1",  // Nerd Font: nf-md-firefox
            "(.*) - kitty": " $1",             // Nerd Font: nf-fa-terminal
            "(.*) - nvim": " $1"               // Nerd Font: nf-dev-vim
        }
    },

    // ==========================================
    // CENTER MODULES
    // ==========================================

    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 50,
        "format-icons": {
            "spotify": "󰓇",       // Nerd Font: nf-md-spotify
            "default": "󰎆"        // Nerd Font: nf-md-play_circle
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2>/dev/null",
        "on-click": "playerctl play-pause"
    },

    // ==========================================
    // RIGHT MODULES - DESKTOP OPTIMIZED
    // ==========================================

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰈈",   // Nerd Font: nf-md-eye (awake)
            "deactivated": "󰈉"  // Nerd Font: nf-md-eye_off (sleep)
        },
        "tooltip-format-activated": "Screen sleep: disabled",
        "tooltip-format-deactivated": "Screen sleep: enabled"
    },

    "privacy": {
        "icon-spacing": 4,
        "icon-size": 18,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-out",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ]
    },

    "network": {
        "format-wifi": "󰖩 {essid}",        // Nerd Font: nf-md-wifi
        "format-ethernet": "󰈁 {ifname}",    // Nerd Font: nf-md-ethernet
        "format-disconnected": "󰖪 Disconnected",  // Nerd Font: nf-md-wifi_off
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n󰕒 {bandwidthUpBits} 󰇚 {bandwidthDownBits}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}\n󰕒 {bandwidthUpBits} 󰇚 {bandwidthDownBits}",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "󰕾 {volume}%",           // Nerd Font: nf-md-volume_high
        "format-muted": "󰖁 muted",         // Nerd Font: nf-md-volume_mute
        "on-click-right": "pavucontrol",
        "scroll-step": 5
    },

    "memory": {
        "interval": 3,
        "format": "󰍛 {percentage}%",
        "states": {
            "warning": 80,
            "critical": 95
        },
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },

    "cpu": {
        "interval": 3,
        "format": "󰻠 {usage}%",           // Nerd Font: nf-md-cpu
        "tooltip": false
    },

    "hyprland/language": {
        "format": "󰌌 {}",            // Nerd Font: nf-md-keyboard
        "format-en": "EN",
        "format-ja": "JP",
        "format-zh": "ZH"
    },

    "clock": {
        "interval": 5,
        "format": "{:%I:%M %p}",
        "format-alt": "{:%Y-%m-%d %I:%M:%S %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "tray": {
        "spacing": 10
    },

    "custom/pomodoro": {
        "exec": "~/.config/waybar/scripts/waybar-pomodoro status",
        "interval": 1,
        "return-type": "json",
        "format": "{}",
        "on-click": "~/.config/waybar/scripts/waybar-pomodoro toggle",
        "on-click-right": "~/.config/waybar/scripts/waybar-pomodoro next",
        "on-click-middle": "~/.config/waybar/scripts/waybar-pomodoro reset",
        "tooltip": true
    },

    "custom/layout": {
        "exec": "hyprctl activewindow -j | jq -r '.grouped | if . == [] then \"split\" else \"group\" end'",
        "interval": 1,
        "format": "{}",
        "tooltip": false
    }

    // "custom/mcp": {
    //     "return-type": "json",
    //     "format": "{}",
    //     "exec": "~/.config/waybar/scripts/waybar-mcp.sh",
    //     "interval": 1,
    //     "signal": 8,
    //     "tooltip": true,
    //     "escape": true,
    //     "on-click": "~/.config/waybar/scripts/waybar-mcp.sh --clear",
    //     "on-click-right": "~/.config/waybar/scripts/waybar-mcp.sh --clear"
    // }
}
// vi:syntax=json
