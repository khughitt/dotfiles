# create archive from a list of files
tar -czvf files.tgz `cat filelist.txt`

# list contents
tar tzvpf foo.tar.gz

# extract specific file/folder
tar xavpf dat.tar.xz target/

# exclude files (do not include trailing slashes for folders)
tar --exclude "*.png" --exclude "*.jpg" czvpf file.tgz input/
