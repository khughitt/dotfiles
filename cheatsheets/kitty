# copy terminfo over
kitty +kitten ssh myserver

# list available fonts
kitty +list-fonts

# copy & paste
ctrl+shift+c   # copy to clipboard
ctrl+shift+v   # paste from clipboard
ctrl+;         # show clipboard manager

# themes
kitten themes

# load scrollback buffer into $PAGER
ctrl+shift+h

# search scrollback in a page
ctrl+shift+/

# increase / decrease background opacity
ctrl+shift+a > m
ctrl+shift+a > l

# choose url to launch
ctrl+shift+e

# shell integration
ctrl+shift+g              # open output from last command in pager
ctrl+shift+right-click    # right click output to open in pager
ctrl+shift+z              # scroll to previous shell prompt
ctrl+shift+x              # scroll to next shell prompt

