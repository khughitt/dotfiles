# list columns
xan headers in.csv

# preview file
xan view in.csv

# select, filter, print
xan filter 'eq(category, "foo")' input.tsv \
    | xan slice -l 10 \
    | xan select '1:6' \
    | xan view

# filter
xan filter 'x == 5'
xan filter 'eq(category, "foo")'
xan filter 'category =~ "^foo$"'

# sort
xan sort -s col_name
